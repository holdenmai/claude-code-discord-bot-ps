# Discord Bot Token
# Get this from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Your Discord User ID (bot will only respond to this user)
ALLOWED_USER_ID=your_discord_user_id

# Base folder path where Claude Code will operate
# Channel names will be appended to this path
BASE_FOLDER=/Users/your-user-name/repos

# Uncomment to enable reactions to prompt messages.
#ENABLE_REACTIONS=true

# Customize the reaction for different status
#REACTION_PROCESSING=:handshake:
#REACTION_SUCCESS=:thumbsup:
#REACTION_PARTIAL=:fingers_crossed:
#REACTION_FAILED=:thumbsdown:

# Uncomment to post activity links to "general" channel in home category
# (and to parent channels for thread activity)
#ACTIVITY_LINKS=true

# Style: plaintext (default), embed, or link (just the URL)
#ACTIVITY_LINK_STYLE=plaintext